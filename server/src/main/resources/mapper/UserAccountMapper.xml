<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.user.returnsassistant.mapper.UserAccountMapper">
    <select id="getById" resultType="com.user.returnsassistant.pojo.UserAccount">
        select * from user_account where id=#{id}
    </select>

    <select id="getByUsername" resultType="com.user.returnsassistant.pojo.UserAccount">
        select * from user_account where username=#{username}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into user_account(username, display_name, role, phone, password_hash, status)
        values(#{username}, #{displayName}, #{role}, #{phone}, #{passwordHash}, #{status})
    </insert>
</mapper>
