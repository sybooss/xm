flowchart LR
    guest["游客/未登录用户"]:::actor
    customer["客户"]:::actor
    admin["客服/管理员"]:::actor
    aiProvider["外部 AI 模型服务<br/>OpenAI-compatible / sub2api"]:::external

    subgraph system["电商退换货智能客服系统"]
        direction LR

        subgraph customerUse["客户侧用例"]
            direction TB
            login(["注册/登录"])
            customerAfterSale(["售后自助<br/>查看订单、提交申请、补充凭证、跟踪进度"])
            onlineConsult(["在线咨询<br/>创建会话、绑定订单、发送问题"])
            serviceReview(["提交服务评价"])
        end

        subgraph adminUse["管理侧用例"]
            direction TB
            reviewAfterSale(["售后审核<br/>要求补材料、通过、驳回、完成"])
            ticketManage(["人工工单处理<br/>创建、分派、跟进"])
            orderManage(["订单与售后记录管理"])
            knowledgeManage(["知识库管理<br/>分类、文档、关键词"])
            slaProfile(["SLA 与客户画像<br/>风险任务、客户聚合信息"])
        end

        subgraph aiUse["AI 支撑与运维用例"]
            direction TB
            intentIdentify(["识别售后意图"])
            knowledgeRetrieve(["检索知识库依据"])
            aiAnswer(["生成 AI 增强回复"])
            aiDraft(["生成客服回复草稿"])
            modelOps(["AI 测试、模型切换与日志诊断"])
        end
    end

    guest --- login
    customer --- login
    customer --- customerAfterSale
    customer --- onlineConsult
    customer --- serviceReview
    admin --- login
    admin --- onlineConsult
    admin --- reviewAfterSale
    admin --- ticketManage
    admin --- orderManage
    admin --- knowledgeManage
    admin --- slaProfile
    admin --- modelOps

    serviceReview -.->|extend| customerAfterSale
    reviewAfterSale -.->|include| orderManage
    ticketManage -.->|extend| reviewAfterSale
    onlineConsult -.->|include| intentIdentify
    onlineConsult -.->|include| knowledgeRetrieve
    onlineConsult -.->|include| aiAnswer
    aiAnswer -.->|include| knowledgeRetrieve
    aiAnswer -.->|include| intentIdentify
    aiDraft -.->|include| knowledgeRetrieve
    modelOps -.->|include| aiAnswer

    aiProvider --- aiAnswer
    aiProvider --- aiDraft
    aiProvider --- modelOps

    classDef actor fill:#fff7ed,stroke:#ea580c,stroke-width:2px,color:#7c2d12;
    classDef external fill:#eef2ff,stroke:#4f46e5,stroke-width:2px,color:#312e81;
    classDef default fill:#ffffff,stroke:#2563eb,stroke-width:1.6px,color:#111827;
    style system fill:#f8fafc,stroke:#334155,stroke-width:2px,color:#0f172a;
    style customerUse fill:#eff6ff,stroke:#2563eb,stroke-width:1.5px,color:#1e3a8a;
    style adminUse fill:#fff7ed,stroke:#f97316,stroke-width:1.5px,color:#7c2d12;
    style aiUse fill:#f0fdfa,stroke:#0f766e,stroke-width:1.5px,color:#134e4a;
